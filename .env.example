# LLM API 配置
# 可选值：kimi、kimi_coding、openai、claude
LLM_PROVIDER=kimi_coding

KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=moonshot-v1-8k
KIMI_CODING_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_openai_model_here

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=your_claude_model_here

# JWT 配置
JWT_SECRET_KEY=your_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 数据库配置
DATABASE_URL=sqlite:///./data/web.db

# CORS 配置
CORS_ORIGINS=*

# 服务器配置（部署时修改为实际 IP）
SERVER_HOST=localhost
SERVER_PORT=8000

# 前端配置（自动从 SERVER_HOST 和 SERVER_PORT 生成）
VITE_API_URL=http://${SERVER_HOST}:${SERVER_PORT}
VITE_WS_URL=ws://${SERVER_HOST}:${SERVER_PORT}
