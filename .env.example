# LLM API 配置
# 可选值：kimi、kimi_coding、openai、claude
LLM_PROVIDER=kimi

KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=kimi-k2.6
KIMI_CODING_MODEL=kimi-k2.6

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_openai_model_here

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=your_claude_model_here

# 思考模式默认开启；关闭可设为 false / off / 0
LLM_THINKING_ENABLED=true
# OpenAI reasoning_effort: none/minimal/low/medium/high/xhigh
LLM_THINKING_EFFORT=medium
# Anthropic thinking budget_tokens，必须小于请求 max_tokens
LLM_THINKING_BUDGET_TOKENS=1024
# Kimi 思考上下文保留策略，默认保留历史 reasoning_content
LLM_THINKING_KEEP=all
# Anthropic thinking 展示策略，默认不把思考正文返回到普通输出
LLM_THINKING_DISPLAY=omitted

# CLI 记忆功能默认关闭；设为 true 或运行 `--memory` 才会沉淀/读取记忆
MEMORY_ENABLED=false
# Agent 单次回复最多允许的工具调用轮数
MAX_TOOL_ROUNDS=100
# 子 Agent 同步任务的 LLM 请求超时时间，默认比主 Agent 稍长
SUB_AGENT_TIMEOUT=600
DATABASE_URL=sqlite:///./data/agent_memory.db

# CLI 默认工作 sandbox，可被 `--workdir <path>` 覆盖
WORKDIR=./data/novels
# 本地创作 skill 目录，可用逗号配置多个；相对路径按仓库根目录解析
SKILL_DIRS=./backend/skills
